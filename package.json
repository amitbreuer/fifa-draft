{
  "name": "fifa-draft",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "projects/shared",
    "projects/client",
    "projects/server"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @fifa-draft/server",
    "dev:client": "npm run start -w @fifa-draft/client",
    "build:server": "npm run build -w @fifa-draft/server",
    "build:client": "npm run build -w @fifa-draft/client",
    "db:generate": "npm run db:generate -w @fifa-draft/server",
    "db:push": "npm run db:push -w @fifa-draft/server"
  }
}
